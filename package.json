{
  "name": "hephcad",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "Open-source, iPad-first, touch/Pencil-friendly B-rep direct modeling CAD (Shapr3D-inspired UX).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
